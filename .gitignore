# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
*.tsbuildinfo

# Data (exclude large files, keep structure)
data/raw/*
!data/raw/.gitkeep
data/curated/*
!data/curated/.gitkeep
data/images/*
!data/images/.gitkeep

# Artifacts (exclude built artifacts)
artifacts/faiss/*
!artifacts/faiss/.gitkeep
artifacts/metadata/*
!artifacts/metadata/.gitkeep
artifacts/models/*.onnx
artifacts/manifests/*
!artifacts/manifests/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Env files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# CDK
infra/cdk.out/
infra/.cdk.staging/

# Temp
*.tmp
.cache/
