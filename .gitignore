# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
*.tsbuildinfo

# Data - Store curated data in Git LFS, exclude raw/images
data/raw/**
data/images/**
!data/.gitkeep
# Curated data (JSONL) stored in Git LFS
!data/curated/**/*.jsonl

# Pipeline state files (temporary, should not be committed)
data/state/
data/state/**

# Price data (will be stored in Git LFS or S3 depending on size)
data/prices/
.temp/

# Artifacts - Store indices/embeddings in Git LFS, exclude large files
# FAISS indices and embeddings stored in Git LFS
!artifacts/faiss/**
!artifacts/metadata/**
# Exception: Keep tiny samples for development
!artifacts/samples/**
!artifacts/.gitkeep

# Generated manifests (temporary, regenerated on each build)
artifacts/manifests/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Env files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# CDK
infra/cdk.out/
infra/.cdk.staging/

# Temp
*.tmp
.cache/

# CI backups (created during workflow runs, should not be committed)
backups/

# Data packages (too large for Git - upload to GitHub Releases instead)
*.zip
cardflux-data-*.zip

# Testing
coverage/
.nyc_output/

# Desktop app build artifacts
apps/desktop/.bundle-temp/
apps/desktop/resources/python-runtime/

# Test coverage
.coverage
**/.coverage

# Local npm config
.npmrc

# Local data directory
services/data/
