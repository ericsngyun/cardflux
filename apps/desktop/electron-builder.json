{
  "appId": "com.cardflux.desktop",
  "productName": "CardFlux",
  "directories": {
    "output": "out",
    "buildResources": "resources"
  },
  "files": [
    "dist/**/*",
    "src/python/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "src/python",
      "to": "python-scripts",
      "filter": ["**/*"]
    },
    {
      "from": "../../artifacts/faiss",
      "to": "artifacts/faiss",
      "filter": ["**/*"]
    },
    {
      "from": "../../artifacts/metadata",
      "to": "artifacts/metadata",
      "filter": ["**/*"]
    },
    {
      "from": "../../artifacts/keypoints",
      "to": "artifacts/keypoints",
      "filter": ["**/*"]
    },
    {
      "from": "../../data/curated",
      "to": "data/curated",
      "filter": ["one-piece-card-game.jsonl"]
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "category": "public.app-category.utilities",
    "hardenedRuntime": false,
    "gatekeeperAssess": false
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Utility"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
