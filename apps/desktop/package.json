{
  "name": "@cardflux/desktop",
  "version": "1.0.0",
  "description": "CardFlux Desktop - Real-time Trading Card Scanner",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-forge start",
    "build": "pnpm bundle:python && webpack --mode production && electron-builder",
    "build:webpack": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "package": "electron-builder",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rimraf dist out resources/python-runtime resources/python-site-packages resources/python-scripts",
    "bundle:python": "node scripts/build/bundle-python.js",
    "bundle:python:windows": "node scripts/build/bundle-python-windows.js",
    "bundle:python:macos": "node scripts/build/bundle-python-macos.js",
    "bundle:python:linux": "node scripts/build/bundle-python-linux.js",
    "bundle:verify": "node scripts/build/verify-bundle.js",
    "bundle:clean": "rimraf resources/python-runtime resources/python-site-packages resources/python-scripts"
  },
  "keywords": [
    "electron",
    "trading-cards",
    "scanner",
    "computer-vision"
  ],
  "author": "CardFlux",
  "license": "MIT",
  "dependencies": {
    "@cardflux/config": "workspace:*",
    "@cardflux/shared": "workspace:*",
    "electron": "^28.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tar": "^7.4.3",
    "tesseract.js": "^5.0.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.0.0",
    "onnxruntime-node": "^1.16.0",
    "opencv4nodejs": "^5.6.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/tar": "^6.1.13",
    "adm-zip": "^0.5.16",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^6.8.1",
    "electron-builder": "^24.9.0",
    "eslint": "^8.56.0",
    "glob": "^11.0.0",
    "html-webpack-plugin": "^5.6.4",
    "p-limit": "^4.0.0",
    "rimraf": "^6.0.1",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
